# Use an official lightweight Python image
FROM python:3.10-slim

# Set working directory inside the container
WORKDIR /app

# Install system dependencies required for build stability
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy and install dependencies first (利用 Docker layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy all repository components into the container
COPY . .

# Expose the network port FastAPI runs on
EXPOSE 8000

# Start up the server using uvicorn pointing to the api subfolder app
CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]